# Database Configuration
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_URL=your_db_url
DB_NAME=your_db_name

# NextAuth — required for JWT sessions (openssl rand -base64 32).
# In production, omitting NEXTAUTH_SECRET causes /api/auth/session to return 500 (CLIENT_FETCH_ERROR in the browser).
NEXTAUTH_SECRET=

# Used by next.config.js: DEV server reads NEXTAUTH_URL_DEV, production build reads NEXTAUTH_URL_PROD.
# Either name works as a fallback: plain NEXTAUTH_URL is used if the _DEV / _PROD variable is unset.
# Value should match how you open the app (scheme + host + port), often with path /api/auth (this project).
NEXTAUTH_URL_DEV=http://localhost:3003/api/auth
NEXTAUTH_URL_PROD=https://yourdomain.com/api/auth

# Next Script URL DEV
NEXTSCRIPT_URL=http://localhost:3003
# Next Script URL PROD
NEXTSCRIPT_URL=https://yourdomain.com
